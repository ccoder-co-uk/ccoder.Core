        "Html":  "\u003cdiv class=\"site-shell\"\u003e\n    \u003cheader class=\"site-header\"\u003e\n        \u003cdiv class=\"container-xxl\"\u003e\n            \u003cdiv class=\"site-header-row\"\u003e\n                \u003ca class=\"site-brand\" href=\"/\" title=\"[app[name]]\"\u003e\n                    \u003cimg src=\"[app[root]]Api/DMS/Content/CompanyLogoTransparent.png\" alt=\"[app[name]]\" /\u003e\u003c/a\u003e\n                \u003cdiv class=\"site-nav-host\"\u003e[component[TopNav]]\u003c/div\u003e\u003cdiv class=\"site-utility\"\u003e\u003cdiv class=\"utility-flags\"\u003e[component[CultureFlags]]\u003c/div\u003e\u003cdiv class=\"utility-time\"\u003e\u003cspan id=\"date\"\u003e\u003c/span\u003e \u003cspan id=\"time\"\u003e\u003c/span\u003e\u003c/div\u003e\u003cdiv class=\"utility-user\"\u003e[component[UserProfile]]\u003c/div\u003e\u003cdiv class=\"utility-help-row\"\u003e\u003cspan class=\"k-icon k-i-infoCircleIcon\"\u003e\u003c/span\u003e\u003ca href=\"/Documentation\" class=\"utility-help\"\u003e[resource_displayname[help]]\u003c/a\u003e\u003c/div\u003e\u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/header\u003e\n    \u003cmain class=\"site-main\"\u003e\u003cdiv class=\"container-xxl\"\u003e\u003cdiv class=\"static-page\"\u003e[content[body]class=tool-shell]\u003c/div\u003e\u003c/div\u003e\u003c/main\u003e\n    \u003cfooter class=\"site-footer\"\u003e\n        \u003cdiv class=\"container-xxl site-footer-inner d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-2\"\u003e\n            \u003cspan\u003e\u0026copy; 2026, cCoder\u003c/span\u003e\n            \u003cspan\u003eStandards-first bespoke cloud software with public documentation and practical platform tools.\u003c/span\u003e\n        \u003c/div\u003e\n    \u003c/footer\u003e\n\u003c/div\u003e\n\u003cscript src=\"/everything.min.js\" crossorigin=\"anonymous\"\u003e\u003c/script\u003e\n\u003cscript\u003e\n    [script[DefaultResourcing]]\n    [script[KendoCultures]]\n    type.dateFormat = \"[resource_displayname[dateformat]]\";\n    type.shortDateFormat = \"[resource_displayname[shortdateformat]]\";\n    type.moneyFormat = \"[resource_displayname[moneyformat]]\";\n    type.aggregateMoneyFormat = \"[resource_displayname[aggregateMoneyFormat]]\";\n\n    initContent();\n\n    kendo.setDefaults(\u0027iconType\u0027, \u0027svg\u0027);\n\n    const targetNode = document.body;\n    const observerConfig = { attributes: true, childList: true, subtree: true };\n    const observer = new MutationObserver(initIcons);\n    observer.observe(targetNode, observerConfig);\n\n    function initIcons() {\n        observer.disconnect();\n\n        $(\".k-icon:not(.k-svg-icon):not(.k-font-icon)\").each(function() {\n            var iconName = $(this).attr(\u0027class\u0027).split(\u0027 \u0027).filter(function(cls) {\n                return cls !== \u0027k-icon\u0027;\n            })[0].replace(/^k-i-/, \"\").replace(\"source-code\", \"code\");\n\n            var svgIcon = kendo.ui.icon({ icon: iconName, type: \u0027svg\u0027 });\n\n            if(svgIcon != `\u003cspan class=\"k-icon k-svg-icon\" aria-hidden=\"true\"\u003e\u003c/span\u003e`) {\n                $(this).replaceWith(svgIcon);\n            }\n        });\n\n        observer.observe(targetNode, observerConfig);\n    }\n\u003c/script\u003e",
        "Script":  null
    }
]
