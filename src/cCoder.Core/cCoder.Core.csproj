<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Library</OutputType>
    <IsPackable>true</IsPackable>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>
  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageTags>cCoder;Core;cCoder.Core</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <PrivateRepositoryUrl>https://github.com/ccoder-co-uk/cCoder.Core.git</PrivateRepositoryUrl>
    <ProjectUrl>https://github.com/ccoder-co-uk/cCoder.Core</ProjectUrl>
    <RepositoryUrl>https://github.com/ccoder-co-uk/cCoder.Core.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <Description>cCoder.Core</Description>
    <Copyright>2026 Paul Ward</Copyright>
    <Authors>cCoder</Authors>
    <PackageId>cCoder.Core</PackageId>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\..\LICENSE.txt" Pack="true" PackagePath="\" />
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="cCoder.AppSecurity" Version="2026.4.15.2019" />
    <PackageReference Include="cCoder.ContentManagement" Version="2026.4.15.2019" />
    <PackageReference Include="cCoder.Data" Version="2026.4.10.1156" />
    <PackageReference Include="cCoder.DocumentManagement" Version="2026.4.15.2019" />
    <PackageReference Include="cCoder.Eventing.EventLibrary" Version="2026.4.15.1800" />
    <PackageReference Include="cCoder.Eventing.EventLibrary.AzureServiceBus" Version="2026.4.15.1800" />
    <PackageReference Include="cCoder.Logging" Version="2026.4.15.2020" />
    <PackageReference Include="cCoder.Mail" Version="2026.4.15.2051" />
    <PackageReference Include="cCoder.Packaging" Version="2026.4.10.1330" />
    <PackageReference Include="cCoder.Scheduling" Version="2026.4.15.2019" />
    <PackageReference Include="cCoder.Security.Api" Version="2026.2.10.1440" />
    <PackageReference Include="cCoder.Security.Data.EF.MSSQL" Version="2026.2.10.1440" />
    <PackageReference Include="cCoder.Security.Objects" Version="2026.2.10.1440" />
    <PackageReference Include="cCoder.Workflow" Version="2026.4.15.2020" />
    <PackageReference Include="cCoder.Workflow.Activities" Version="2026.4.15.2020" />
    <PackageReference Include="Microsoft.AspNetCore.OData" Version="9.4.1" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.5" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="System.Linq.Dynamic.Core" Version="1.7.1" />
    <PackageReference Include="itext" Version="9.5.0" />
    <PackageReference Include="itext.pdfhtml" Version="6.3.1" />
    <PackageReference Include="itext.bouncy-castle-adapter" Version="9.5.0" />
    <PackageReference Include="Swashbuckle.AspNetCore.Swagger" Version="10.1.5" />
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerGen" Version="10.1.5" />
    <PackageReference Include="Swashbuckle.AspNetCore.SwaggerUI" Version="10.1.5" />
  </ItemGroup>
</Project>

