  <ItemGroup>
    <ProjectReference Include="..\..\cCoder.Core.Api\cCoder.Core.Api.csproj" />
    <ProjectReference Include="..\..\cCoder.Core.Services\cCoder.Core.Services.csproj" />
    <ProjectReference Include="..\..\cCoder.Core.Data\cCoder.Core.Data.csproj" />
    <ProjectReference Include="..\..\cCoder.Core.Objects\cCoder.Core.Objects.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Update="wwwroot\css\site.css">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Update="wwwroot\lib\queuestats.js">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
