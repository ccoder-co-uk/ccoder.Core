@inject IConfiguration Configuration
@{
    string webHost = Context.Request.Host.Host;
    string configuredSslPort = Configuration["Settings:sslPort"] ?? string.Empty;
    string webRoot = string.IsNullOrWhiteSpace(configuredSslPort)
        ? $"https://{webHost}"
        : $"https://{webHost}:{configuredSslPort}";

    ViewData["WebRoot"] = webRoot.TrimEnd('/');
}
<!DOCTYPE html>
<html>
    <head>
        <title></title>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">

        <script src="https://code.jquery.com/jquery-3.7.0.min.js" crossorigin="anonymous"></script>
        <script src="/signalr.min.js"></script>

        <link rel="stylesheet"
              href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
              integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
              crossorigin="anonymous">
        <link rel="stylesheet" href="@($"{webRoot}/everything.min.css")" />
        <link rel="stylesheet" href="/css/hostedservices.css" />
    </head>

    <body class="container hosted-services-dashboard">
        @RenderBody()
    </body>
</html>
